# FFTrix Environment Configuration
# Copy this file to .env and fill in your values.

# REQUIRED: A random secret key used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FFTRIX_SECRET_KEY=change-me-to-a-random-32-char-string

# Optional overrides (defaults shown)
FFTRIX_PORT=8080
FFTRIX_HOST=0.0.0.0

# ── Email Alerts (SMTP) ──────────────────────────────────────────────────────
# Leave blank to disable email alerts entirely.
# Example shown for Gmail with App Passwords (https://myaccount.google.com/apppasswords)
FFTRIX_SMTP_HOST=smtp.gmail.com
FFTRIX_SMTP_PORT=587
FFTRIX_SMTP_USER=your-email@gmail.com
FFTRIX_SMTP_PASSWORD=your-app-password
FFTRIX_ALERT_FROM=fftrix@your-domain.com

# ── Remote Access (Tailscale Funnel & Angie) ─────────────────────────────────
# TS_AUTHKEY=tskey-auth-xxxxxx  # Optional: For automated Tailscale authentication
# ANGIE_CONF_PATH=~/.fftrix/angie.conf  # Generated automatically
# TS_FUNNEL_URL=your-hostname.tail-rnd234.dev.ts.net
